# ─── Copie para .env.local e preencha os valores reais ───

# ── Google Analytics 4 ──
# Obtenha em: https://analytics.google.com → Admin → Data Streams → Web
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site URL (usado pelo metadataBase no layout.tsx) ──
NEXT_PUBLIC_SITE_URL=https://seusite.com

# ── Google Search Console (opcional) ──
# Substitua no layout.tsx em verification.google
# GOOGLE_SEARCH_CONSOLE_TOKEN=XXXXXXXXXXXX
